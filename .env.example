# ===== Backend Configuration =====
APP_ENV=dev
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_FULLNAME=Administrator

# SQLite Database (no PostgreSQL needed)
DATABASE_URL=sqlite:///./visitors.db

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Default Camera
DEFAULT_CAMERA_NAME=Kamera Utama
DEFAULT_CAMERA_LOCATION=Pintu Masuk Utama
DEFAULT_CAMERA_STREAM=

# ===== Edge Configuration =====
EDGE_MODE=real           # fake | real
EDGE_CAMERA_ID=1
EDGE_POST_INTERVAL_SECONDS=3
EDGE_CONFIG_REFRESH_SECONDS=30

# Backend API URL (local, no Docker)
BACKEND_URL=http://localhost:8000

# ===== Camera Source =====
# Edge worker bisa langsung baca webcam TANPA perlu Flask rtsp server terpisah.
# Pilihan:
#   "0"                         → webcam langsung (index 0)
#   "1"                         → webcam index 1
#   "http://localhost:8081/video" → jika tetap mau pakai rtsp_webcam_server.py
#   "rtsp://ip:port/stream"     → IP camera RTSP
# EDGE_STREAM_URL=rtsp://admin:admin@10.185.124.81:554/live/ch00_0
EDGE_STREAM_URL=http://127.0.0.1:7000/video

# Port untuk menyajikan video hasil proses YOLO+tracking ke frontend
EDGE_STREAM_PORT=5000

# Auth credentials for edge to backend
EDGE_AUTH_USERNAME=admin
EDGE_AUTH_PASSWORD=admin123

# ===== YOLOv5 Configuration =====
YOLOV5_CONF=0.35
YOLOV5_IOU=0.45
YOLOV5_IMG_SIZE=640
YOLOV5_DEVICE=cpu        # cpu | cuda:0 | xpu (Intel GPU)
YOLOV5_REPO=
YOLOV5_WEIGHTS=

# Tracking Configuration
TRACK_MAX_DISAPPEARED=20
TRACK_MAX_DISTANCE=80

# ===== Employee Face Filtering =====
FACE_RECOGNITION_ENABLED=true
INSIGHTFACE_MODEL_NAME=buffalo_l
INSIGHTFACE_DET_SIZE=640
EMPLOYEE_MATCH_THRESHOLD=0.45
EMPLOYEE_REGISTRY_REFRESH_SECONDS=60
FACE_RECHECK_SECONDS=0.8
FACE_UNKNOWN_TIMEOUT=2.5

# ===== Frontend Configuration =====
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_STREAM_URL=http://localhost:5000/video_feed
