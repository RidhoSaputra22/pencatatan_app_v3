# ===== Backend Bootstrap & Secrets =====
APP_ENV=dev
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALG=HS256
JWT_EXP_MINUTES=1440
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_FULLNAME=Administrator

DATABASE_URL=sqlite:///./backend/visitors.db
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_PUBLIC_URL=

# ===== Initial Data Seed =====
DEFAULT_CAMERA_NAME=Kamera Utama
DEFAULT_CAMERA_LOCATION=Pintu Masuk Utama
DEFAULT_CAMERA_STREAM=
DEFAULT_AREA_NAME=Gate Masuk
DEFAULT_AREA_DIRECTION_MODE=BOTH
DEFAULT_AREA_ROI_POLYGON=[[50,50],[1230,50],[1230,670],[50,670]]
EMPLOYEE_FACES_DIR=./backend/storage/employee_faces

# ===== Face Model Bootstrap =====
INSIGHTFACE_MODEL_NAME=buffalo_l
INSIGHTFACE_DET_SIZE=640
INSIGHTFACE_PROVIDERS=CPUExecutionProvider

# ===== Edge Bootstrap =====
EDGE_MODE=real
EDGE_CAMERA_ID=1
EDGE_POST_INTERVAL_SECONDS=3
BACKEND_URL=http://localhost:8000
EDGE_PUBLIC_BASE_URL=http://localhost:5000

EDGE_STREAM_HOST=0.0.0.0
EDGE_STREAM_PORT=5000
EDGE_STREAM_ALLOW_ORIGIN=*
EDGE_WEBRTC_ENABLED=true
EDGE_WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
EDGE_CAPTURE_OPEN_TIMEOUT_MS=8000
EDGE_CAPTURE_READ_TIMEOUT_MS=1500
EDGE_CAPTURE_FFMPEG_OPTIONS=rtsp_transport;tcp|timeout;5000000|rw_timeout;5000000|fflags;nobuffer|flags;low_delay|max_delay;500000|reorder_queue_size;0

# Runtime tuning lives in backend/storage/runtime_config.json via the dashboard.

# ===== Frontend Bootstrap =====
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE=
NEXT_PUBLIC_POLL_INTERVAL_MS=30000
NEXT_PUBLIC_STREAM_HEALTH_INTERVAL_MS=15000

# ===== Edge Auth =====
EDGE_AUTH_USERNAME=admin
EDGE_AUTH_PASSWORD=admin123

# ===== Relay Bootstrap =====
RTSP_SOURCE=0
UDP_RELAY_HOST=0.0.0.0
UDP_RELAY_PORT=9999
RTSP_SERVER_HOST=0.0.0.0
RTSP_SERVER_PORT=7000
RTSP_JPEG_QUALITY=75
RTSP_TARGET_FPS=0
