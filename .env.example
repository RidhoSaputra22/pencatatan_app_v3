# ===== Backend Configuration =====
APP_ENV=dev
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALG=HS256
JWT_EXP_MINUTES=1440
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_FULLNAME=Administrator

# SQLite Database (no PostgreSQL needed)
DATABASE_URL=sqlite:///./backend/visitors.db

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Default Camera
DEFAULT_CAMERA_NAME=Kamera Utama
DEFAULT_CAMERA_LOCATION=Pintu Masuk Utama
DEFAULT_CAMERA_STREAM=
DEFAULT_AREA_NAME=Gate Masuk
DEFAULT_AREA_DIRECTION_MODE=BOTH
DEFAULT_AREA_ROI_POLYGON=[[50,50],[1230,50],[1230,670],[50,670]]
EMPLOYEE_FACES_DIR=./backend/storage/employee_faces
INSIGHTFACE_MODEL_NAME=buffalo_l
INSIGHTFACE_DET_SIZE=640
INSIGHTFACE_PROVIDERS=CPUExecutionProvider

# ===== Edge Configuration =====
EDGE_MODE=real           # fake | real
EDGE_CAMERA_ID=1
EDGE_POST_INTERVAL_SECONDS=3
EDGE_CONFIG_REFRESH_SECONDS=30

# Backend API URL (local, no Docker)
BACKEND_URL=http://localhost:8000
EDGE_PUBLIC_BASE_URL=http://localhost:5000

# ===== Frontend Runtime =====
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000
NEXT_PUBLIC_POLL_INTERVAL_MS=30000
NEXT_PUBLIC_STREAM_HEALTH_INTERVAL_MS=5000

# ===== Camera Source =====
# Edge worker membaca video stream untuk diproses YOLO+tracking.
#
# Pilihan EDGE_STREAM_URL:
#   "0"                                     → webcam langsung (index 0)
#   "1"                                     → webcam index 1
#   "http://localhost:8081/video"            → jika tetap mau pakai rtsp_webcam_server.py
#   "rtsp://ip:port/stream"                 → IP camera RTSP
#   "http://localhost:8000/stream/relay"     → dari client via UDP (streaming dari frontend)
#
# Untuk mode CLIENT → SERVER (streaming via UDP):
#   1. Set EDGE_STREAM_URL ke backend relay:
#      EDGE_STREAM_URL=http://localhost:8000/stream/relay
#   2. Jalankan client streamer di PC lokal:
#      python client/streamer.py --source 0 --server-ip <SERVER_IP> --server-port 9999
#
# EDGE_STREAM_URL=rtsp://admin:admin@10.185.124.81:554/live/ch00_0
EDGE_STREAM_URL=http://127.0.0.1:7000/video
EDGE_STREAM_HOST=0.0.0.0

# Port untuk menyajikan video hasil proses YOLO+tracking ke frontend
EDGE_STREAM_PORT=5000
EDGE_STREAM_JPEG_QUALITY=80
EDGE_STREAM_MAX_FPS=0
EDGE_STREAM_ALLOW_ORIGIN=*

# Auth credentials for edge to backend
EDGE_AUTH_USERNAME=admin
EDGE_AUTH_PASSWORD=admin123

# ===== YOLOv5 Configuration =====
YOLOV5_CONF=0.35
YOLOV5_IOU=0.45
YOLOV5_IMG_SIZE=640
YOLOV5_DEVICE=cpu        # cpu | cuda:0 | xpu (Intel GPU)
YOLOV5_REPO=
YOLOV5_WEIGHTS=./edge/yolov5s.pt

# Tracking Configuration
TRACK_MAX_DISAPPEARED=20
TRACK_MAX_DISTANCE=80
TRACK_CONFIRM_FRAMES=1

# ===== Employee Face Filtering =====
FACE_RECOGNITION_ENABLED=true
EMPLOYEE_MATCH_THRESHOLD=0.45
EMPLOYEE_REGISTRY_REFRESH_SECONDS=60
FACE_RECHECK_SECONDS=0.8
FACE_UNKNOWN_TIMEOUT=2.5

# ===== Optional RTSP / HTTP Relay =====
RTSP_SOURCE=0

# ===== UDP Stream Relay (Client → Server) =====
# Port untuk menerima stream UDP dari client
UDP_RELAY_HOST=0.0.0.0
UDP_RELAY_PORT=9999
RTSP_SERVER_HOST=0.0.0.0
RTSP_SERVER_PORT=7000
RTSP_JPEG_QUALITY=75
RTSP_TARGET_FPS=0
